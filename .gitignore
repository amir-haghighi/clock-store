# =========================
# MERN Stack .gitignore
# =========================

# -------------------------
# Dependencies
# -------------------------
node_modules/
.pnp
.pnp.js

# -------------------------
# Logs
# -------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# Environment Variables
# -------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -------------------------
# Build / Production
# -------------------------
dist/
build/
.next/
out/
coverage/

# -------------------------
# React / Frontend
# -------------------------
frontend/node_modules/
frontend/build/
frontend/dist/

# Vite
vite.svg

# -------------------------
# Express / Backend
# -------------------------
backend/node_modules/
backend/dist/
backend/build/

# Uploads (optional)
uploads/
public/uploads/

# -------------------------
# MongoDB
# -------------------------
data/
*.mongodb

# -------------------------
# Cache
# -------------------------
.cache/
.parcel-cache/
.eslintcache

# -------------------------
# OS Files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# IDE / Editor
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo

# -------------------------
# Testing
# -------------------------
coverage/
.nyc_output/

# -------------------------
# Misc
# -------------------------
tmp/
temp/
*.pem